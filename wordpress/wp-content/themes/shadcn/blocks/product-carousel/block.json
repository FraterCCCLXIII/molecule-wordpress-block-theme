{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "molecule/product-carousel",
	"version": "1.0.0",
	"title": "Product Carousel",
	"category": "molecule",
	"description": "A horizontally scrollable WooCommerce product carousel with prev/next scroll buttons.",
	"keywords": [ "products", "carousel", "woocommerce", "shop" ],
	"textdomain": "shadcn",
	"editorScript": "file:./build/index.js",
	"editorStyle": "file:./build/index.css",
	"viewScript": "file:./build/view.js",
	"style": "file:./build/style-view.css",
	"render": "file:./render.php",
	"attributes": {
		"perPage": {
			"type": "number",
			"default": 12
		}
	},
	"supports": {
		"html": false,
		"inserter": true,
		"multiple": true,
		"align": [ "wide", "full" ]
	}
}
